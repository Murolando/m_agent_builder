# Hydra (OpenAI-совместимый API). HYDRA_API_KEY обязателен.
HYDRA_API_KEY=
HYDRA_BASE_URL=https://api.hydraai.ru/v1
HYDRA_LLM_MODEL=gpt-4o-mini
HYDRA_EMBED_MODEL=text-embedding-3-small

# PostgreSQL + pgvector.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ragdb?sslmode=disable
PG_COLLECTION=knowledge_base
# Размерность эмбеддингов: text-embedding-3-small = 1536.
VECTOR_SIZE=1536

# Агент.
AGENT_MAX_STEPS=5
RAG_TOP_K=3

# HTTP-сервер.
SERVER_PORT=8080
